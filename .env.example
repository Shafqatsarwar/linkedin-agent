# LinkedIn OAuth Credentials (get from https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback

# Gemini API Key (get from https://ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Server port (default: 8000)
PORT=8000

# Optional: Comma-separated allowed origins for CORS (default: http://localhost:8000)
# Add your Render URL here when deploying: https://myapp.onrender.com,http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8000

# Optional: Secret key for session encryption (use a long random string in production)
SECRET_KEY=dev-secret
